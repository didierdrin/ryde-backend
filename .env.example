# Database Configuration - Neon PostgreSQL
# Set this in Railway environment variables
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require&channel_binding=require

# JWT Secret - Set a strong random string in Railway
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# CORS Configuration - Add your frontend URLs (comma-separated, no spaces)
# https://ryde-web.vercel.app and http://localhost:* are always allowed in app.js; add others as needed
CORS_ORIGIN=https://ryde-web.vercel.app,http://localhost:3000,http://localhost:5172

# Optional: JWT expiration (default: 7d)
JWT_EXPIRES_IN=7d

# Admin referral code secret (rotates hourly for new admin signups)
# Generate with: openssl rand -base64 32
# Falls back to JWT_SECRET if not set
ADMIN_REFERRAL_SECRET=your-admin-referral-secret-change-this

# --- IremboPay (server: create invoices via @irembo/irembopay-node-sdk) ---
# Secret key from IremboPay dashboard (same account used for the widget public key)
IREMBOPAY_SECRET_KEY=sk_sandbox_your_secret_key
# Public key used by the inline widget (web/mobile WebView)
IREMBOPAY_PUBLIC_KEY=pk_sandbox_your_public_key
# sandbox | checkout | production
IREMBOPAY_ENVIRONMENT=sandbox
# Payment account identifier from dashboard (phone MSISDN or account id as shown in IremboPay)
IREMBOPAY_ACCOUNT_ID=0780000000
# Product code (PC-…) for line items
IREMBOPAY_PRODUCT_ID=PC-your_product_id

# Shared secret: mozypizza-callbacks forwards webhooks to POST /api/orders/subscribe with this header.
# Must match MOZYPIZZA_INTERNAL_SECRET on the callbacks service (and IREMBOPAY_SECRET_KEY there for HMAC verification).
MOZYPIZZA_INTERNAL_SECRET=generate_a_long_random_string

# --- Export PDF email (Resend API) ---
# Sign up at https://resend.com — free tier includes 3,000 emails/month.
# API key from Resend dashboard (re_…). Set on Railway; never commit the real key.
RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM=onboarding@resend.dev
# Or with display name (quote the value on Railway if it contains spaces):
# RESEND_FROM="RYDE <onboarding@resend.dev>"
RESEND_FROM=onboarding@resend.dev

# Optional: max JSON body for /api/export (default 15mb), max decoded PDF bytes (default 10mb)
# EXPORT_BODY_LIMIT=15mb
# EXPORT_PDF_MAX_BYTES=10485760

# Note: PORT and NODE_ENV are set automatically by Railway
