# Database Configuration - Neon PostgreSQL
# Set this in Railway environment variables
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require&channel_binding=require

# JWT Secret - Set a strong random string in Railway
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# CORS Configuration - Add your frontend URLs (comma-separated, no spaces)
# https://ryde-web.vercel.app is always allowed; add others as needed
CORS_ORIGIN=https://ryde-web.vercel.app

# Optional: JWT expiration (default: 7d)
JWT_EXPIRES_IN=7d

# IremboPay via mozypizza-be (invoice creation only; callbacks handled by mozypizza-callbacks)
MOZYPIZZA_API_URL=https://mozypizza-be-production.up.railway.app/api
MOZYPIZZA_PRODUCT_ID=1
MOZYPIZZA_PRODUCT_UNIT_PRICE=1

# Note: PORT and NODE_ENV are set automatically by Railway
